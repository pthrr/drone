#!/bin/sh
# Minimal initramfs init — wait for root device then switch_root

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# Log to kernel ring buffer (visible on serial even without /dev/console)
log() { echo "initramfs: $*" > /dev/kmsg; }

log "starting"

ROOT=/dev/mmcblk0p68

log "waiting for $ROOT (up to 30s)..."
i=0
while [ ! -b "$ROOT" ] && [ "$i" -lt 300 ]; do
    sleep 0.1
    i=$((i + 1))
done

log "block devices after ${i}00ms:"
ls /dev/mmcblk* 2>/dev/null | while read d; do log "  $d"; done
if ! ls /dev/mmcblk* >/dev/null 2>&1; then
    log "  (no mmcblk devices found)"
fi

if [ ! -b "$ROOT" ]; then
    log "$ROOT not found after 30s, dropping to shell"
    exec /bin/sh
fi

log "mounting $ROOT as ext4"
mkdir -p /mnt
if ! mount -t ext4 -o rw "$ROOT" /mnt; then
    log "mount FAILED (exit $?), dropping to shell"
    exec /bin/sh
fi

if [ -x /mnt/sbin/init ]; then
    log "found /sbin/init"
elif [ -x /mnt/lib/systemd/systemd ]; then
    log "found /lib/systemd/systemd (no /sbin/init)"
else
    log "no init found on rootfs! dropping to shell"
    exec /bin/sh
fi

log "switch_root to /mnt"
umount /proc /sys 2>/dev/null
exec switch_root /mnt /sbin/init

log "switch_root FAILED, dropping to shell"
exec /bin/sh
